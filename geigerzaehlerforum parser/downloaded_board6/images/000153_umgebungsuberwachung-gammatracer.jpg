        </div>
        <div class="mobile-slide-header">
          <div class="menu-main-menu-german-container"><ul id="menu-main-menu-german" class="menu"><li id="menu-item-69054" class="mega-menu-custom menu-item menu-item-type-custom menu-item-object-custom current-menu-ancestor menu-item-has-children real-id-69054"><a href="/industry/industries/" data-id="69054" data-slug="produkte">Produkte</a><span class="text-before-submenu">arrow</span>
